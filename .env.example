# Database Configuration
DATABASE_URL=sqlite:///./streetfood.db
# For production: postgresql://user:password@localhost/streetfood_db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Model Configuration
MODEL_PATH=models/food_classifier.h5
MEAL_TYPE_MODEL_PATH=models/meal_type_classifier.h5
CONFIDENCE_THRESHOLD=0.70

# Application Settings
DEBUG=True
UPLOAD_FOLDER=data/uploads
MAX_UPLOAD_SIZE=10485760

# Admin Credentials (Change in production!)
ADMIN_EMAIL=admin@streetfood.ai
ADMIN_PASSWORD=admin123
